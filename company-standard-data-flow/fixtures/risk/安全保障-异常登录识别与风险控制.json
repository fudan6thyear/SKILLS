{
  "business_name": "安全保障",
  "activity_name": "异常登录识别与风险控制",
  "title_override": "",
  "activity_color": "#2F6B7A",
  "layout": {
    "keep_empty_stages": true,
    "use_store_use_subcolumns": true,
    "store_use_subcolumns": [
      "用户界面",
      "业务系统"
    ]
  },
  "lanes": {
    "data_subject": {
      "entities": [
        {
          "id": "subject_user",
          "name": "用户",
          "type": "human_actor",
          "stage": "信息收集",
          "note": "发起登录并触发账号安全校验"
        }
      ]
    },
    "internal_staff": {
      "entities": []
    },
    "internal_system": {
      "entities": [
        {
          "id": "account_center",
          "name": "账号中心",
          "type": "internal_system",
          "stage": "存储/使用",
          "subcolumn": "业务系统",
          "note": "接收登录请求并向风控平台发起风险判断",
          "layout_hint": {
            "x": 380,
            "y": 401
          }
        },
        {
          "id": "risk_platform",
          "name": "风控平台",
          "type": "internal_system",
          "stage": "存储/使用",
          "subcolumn": "业务系统",
          "note": "综合账号状态、历史风险和第三方评分输出风险结论",
          "layout_hint": {
            "x": 680,
            "y": 401
          }
        },
        {
          "id": "log_platform",
          "name": "日志平台",
          "type": "datastore",
          "stage": "存储/使用",
          "subcolumn": "业务系统",
          "note": "沉淀登录日志和历史风险记录供风控回溯分析",
          "layout_hint": {
            "x": 430,
            "y": 620
          }
        },
        {
          "id": "alert_system",
          "name": "告警系统",
          "type": "internal_system",
          "stage": "分享/传输",
          "note": "接收风险等级和处置策略并触发告警或拦截动作",
          "layout_hint": {
            "x": 860,
            "y": 401
          }
        }
      ]
    },
    "third_party": {
      "entities": [
        {
          "id": "tiandun_risk",
          "name": "天盾风控",
          "type": "third_party_cloud",
          "stage": "分享/传输",
          "note": "提供外部风险评分、风险标签和建议处置动作"
        }
      ]
    }
  },
  "data_items": [
    {
      "id": 1,
      "name": "账号ID",
      "description": "用于识别登录账号的唯一标识",
      "data_type_example": "UID123456",
      "sensitive": false,
      "owner": "平台账号体系",
      "primary_targets": [
        "account_center",
        "risk_platform",
        "log_platform",
        "tiandun_risk"
      ]
    },
    {
      "id": 2,
      "name": "设备指纹",
      "description": "用于识别终端环境和设备特征的指纹信息",
      "data_type_example": "device-fp-9af31c",
      "sensitive": true,
      "owner": "终端环境",
      "primary_targets": [
        "account_center",
        "risk_platform",
        "log_platform",
        "tiandun_risk"
      ]
    },
    {
      "id": 3,
      "name": "IP地址",
      "description": "登录请求来源的网络地址",
      "data_type_example": "203.0.113.10",
      "sensitive": true,
      "owner": "网络层",
      "primary_targets": [
        "account_center",
        "risk_platform",
        "log_platform",
        "tiandun_risk"
      ]
    },
    {
      "id": 4,
      "name": "登录时间",
      "description": "登录事件发生时间",
      "data_type_example": "2026-03-23 20:15:00",
      "sensitive": false,
      "owner": "平台",
      "primary_targets": [
        "account_center",
        "risk_platform",
        "log_platform"
      ]
    },
    {
      "id": 5,
      "name": "地理位置",
      "description": "由登录环境识别出的地理位置信息",
      "data_type_example": "上海市",
      "sensitive": true,
      "owner": "网络层",
      "primary_targets": [
        "account_center",
        "log_platform",
        "risk_platform"
      ]
    },
    {
      "id": 6,
      "name": "账号状态",
      "description": "账号当前的安全或可用状态",
      "data_type_example": "正常/冻结/二次验证中",
      "sensitive": true,
      "owner": "账号中心",
      "primary_targets": [
        "account_center",
        "log_platform",
        "risk_platform"
      ]
    },
    {
      "id": 7,
      "name": "历史风险记录",
      "description": "与账号或设备相关的历史风险事件与命中记录",
      "data_type_example": "异地登录命中记录",
      "sensitive": true,
      "owner": "日志平台",
      "primary_targets": [
        "risk_platform"
      ]
    },
    {
      "id": 8,
      "name": "登录行为特征",
      "description": "用于判断异常登录的行为特征组合",
      "data_type_example": "失败次数、登录频率、设备切换特征",
      "sensitive": true,
      "owner": "风控平台",
      "primary_targets": [
        "risk_platform",
        "tiandun_risk"
      ]
    },
    {
      "id": 9,
      "name": "风险评分",
      "description": "第三方返回的风险量化评分",
      "data_type_example": "92",
      "sensitive": true,
      "owner": "天盾风控",
      "primary_targets": [
        "risk_platform"
      ]
    },
    {
      "id": 10,
      "name": "风险标签",
      "description": "第三方返回的风险类型标签",
      "data_type_example": "撞库风险/盗号风险",
      "sensitive": true,
      "owner": "天盾风控",
      "primary_targets": [
        "risk_platform"
      ]
    },
    {
      "id": 11,
      "name": "建议处置动作",
      "description": "第三方返回的建议处理动作",
      "data_type_example": "要求二次验证",
      "sensitive": false,
      "owner": "天盾风控",
      "primary_targets": [
        "risk_platform"
      ]
    },
    {
      "id": 12,
      "name": "风险等级",
      "description": "风控平台输出的综合风险等级",
      "data_type_example": "高风险",
      "sensitive": true,
      "owner": "风控平台",
      "primary_targets": [
        "alert_system"
      ]
    },
    {
      "id": 13,
      "name": "处置策略",
      "description": "风控平台确定的处置或告警策略",
      "data_type_example": "拦截登录并触发告警",
      "sensitive": false,
      "owner": "风控平台",
      "primary_targets": [
        "alert_system"
      ]
    },
    {
      "id": 14,
      "name": "登录行为",
      "description": "本次登录事件的原始行为记录",
      "data_type_example": "登录请求、尝试结果、会话上下文",
      "sensitive": true,
      "owner": "用户",
      "primary_targets": [
        "account_center",
        "log_platform"
      ]
    }
  ],
  "flows": [
    {
