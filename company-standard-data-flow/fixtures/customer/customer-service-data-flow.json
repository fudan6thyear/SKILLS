{
  "business_name": "客服运营",
  "activity_name": "在线客服咨询与工单处理",
  "activity_color": "#2f6b7a",
  "layout": {
    "keep_empty_stages": true,
    "use_store_use_subcolumns": true,
    "store_use_subcolumns": [
      "用户界面",
      "业务系统"
    ]
  },
  "lanes": {
    "data_subject": {
      "entities": [
        {
          "id": "subject_user",
          "name": "用户",
          "type": "human_actor",
          "stage": "信息收集",
          "note": "通过 App 发起在线咨询、投诉与问题反馈"
        }
      ]
    },
    "internal_staff": {
      "entities": [
        {
          "id": "staff_agent",
          "name": "客服人员",
          "type": "human_actor",
          "stage": "存储/使用",
          "note": "查看咨询会话、处理工单并跟进投诉"
        }
      ]
    },
    "internal_system": {
      "entities": [
        {
          "id": "app_client",
          "name": "App 客户端",
          "type": "ui_function",
          "stage": "信息收集",
          "note": "接收用户咨询、投诉内容并上传截图或录音",
          "layout_hint": {
            "x": 120,
            "y": 525
          }
        },
        {
          "id": "cs_workbench",
          "name": "客服工作台",
          "type": "ui_function",
          "stage": "存储/使用",
          "subcolumn": "用户界面",
          "note": "客服查看会话、处理咨询并同步工单记录",
          "layout_hint": {
            "x": 380,
            "y": 625
          }
        },
        {
          "id": "ticket_system",
          "name": "工单系统",
          "type": "internal_system",
          "stage": "存储/使用",
          "subcolumn": "业务系统",
          "note": "创建、分派、跟踪并更新工单",
          "layout_hint": {
            "x": 670,
            "y": 525
          }
        },
        {
          "id": "user_center",
          "name": "用户中心",
          "type": "internal_system",
          "stage": "存储/使用",
          "subcolumn": "业务系统",
          "note": "提供账号信息和历史订单查询能力",
          "layout_hint": {
            "x": 930,
            "y": 625
          }
        },
        {
          "id": "recording_store",
          "name": "录音/会话存储系统",
          "type": "datastore",
          "stage": "归档/删除",
          "note": "归档录音、截图、会话记录等客服留痕数据",
          "layout_hint": {
            "x": 1280,
            "y": 525
          }
        }
      ]
    },
    "third_party": {
      "entities": [
        {
          "id": "weifu_cloud",
          "name": "微服Cloud",
          "type": "third_party_cloud",
          "stage": "分享/传输",
          "note": "提供机器人答复与摘要生成服务"
        }
      ]
    }
  },
  "data_items": [
    {
      "id": 1,
      "name": "账号ID",
      "description": "用户账号唯一标识",
      "data_type_example": "UID/账号编号",
      "sensitive": false,
      "owner": "用户",
      "primary_targets": [
        "App 客户端",
        "客服工作台",
        "工单系统",
        "用户中心",
        "微服Cloud"
      ]
    },
    {
      "id": 2,
      "name": "手机号",
      "description": "用于身份核验与回访联系",
      "data_type_example": "11位手机号",
      "sensitive": true,
      "owner": "用户",
      "primary_targets": [
        "App 客户端",
        "用户中心",
        "客服工作台"
      ]
    },
    {
      "id": 3,
      "name": "咨询内容/问题描述",
      "description": "用户提交的文本咨询、投诉或问题说明",
      "data_type_example": "文本消息/问题摘要",
      "sensitive": true,
      "owner": "用户",
      "primary_targets": [
        "App 客户端",
        "客服工作台",
        "工单系统",
        "微服Cloud"
      ]
    },
    {
      "id": 4,
      "name": "截图或录音",
      "description": "用户上传的截图、录音等咨询附件",
      "data_type_example": "图片/音频文件",
      "sensitive": true,
      "owner": "用户",
      "primary_targets": [
        "App 客户端",
        "客服工作台",
        "录音/会话存储系统"
      ]
    },
    {
      "id": 5,
      "name": "历史订单信息",
      "description": "客服核查用户咨询时调取的订单历史",
      "data_type_example": "订单号、下单时间、商品信息",
      "sensitive": true,
      "owner": "平台",
      "primary_targets": [
        "用户中心",
        "客服工作台"
      ]
    },
    {
      "id": 6,
      "name": "沟通记录",
      "description": "咨询过程中的客服回复和会话记录",
      "data_type_example": "聊天记录/处理备注",
      "sensitive": true,
      "owner": "平台",
      "primary_targets": [
        "客服工作台",
        "工单系统",
        "录音/会话存储系统"
      ]
    },
    {
      "id": 7,
      "name": "附件元数据",
      "description": "发送给第三方时的附件名称、类型、大小等描述信息",
      "data_type_example": "文件名/类型/哈希",
      "sensitive": false,
      "owner": "平台",
      "primary_targets": [
        "微服Cloud"
      ]
    },
    {
      "id": 8,
      "name": "机器人答复",
      "description": "第三方返回的自动回复建议",
      "data_type_example": "问答文本",
      "sensitive": false,
      "owner": "微服Cloud",
      "primary_targets": [
        "客服工作台"
      ]
    },
    {
      "id": 9,
      "name": "工单编号",
      "description": "用于追踪处理状态的工单标识",
      "data_type_example": "TICKET-2026-0001",
      "sensitive": false,
      "owner": "平台",
      "primary_targets": [
        "客服工作台",
        "录音/会话存储系统"
      ]
    },
    {
      "id": 10,
      "name": "会话摘要",
      "description": "第三方生成的会话总结",
      "data_type_example": "摘要文本",
      "sensitive": false,
      "owner": "微服Cloud",
      "primary_targets": [
        "客服工作台"
      ]
    }
  ],
  "flows": [
    {
      "id": "flow_1",
      "stage": "信息收集",
      "source_entity_id": "subject_user",
      "target_entity_id": "app_client",
      "data_item_ids": [
        1,
        2,
        3,
        4
      ],
      "description": "用户在 App 中提交账号标识、咨询内容以及截图或录音"
    },
    {
      "id": "flow_2",
      "stage": "信息收集",
      "source_entity_id": "app_client",
      "target_entity_id": "cs_workbench",
      "data_item_ids": [
        1,
        3,
        4
      ],
      "description": "App 客户端向客服工作台传输账号ID、咨询内容和截图或录音"
    },
    {
      "id": "flow_3",
      "stage": "存储/使用",
      "source_entity_id": "cs_workbench",
      "target_entity_id": "ticket_system",
      "data_item_ids": [
        1,
        2,
        3,
        6
      ],
      "description": "客服工作台向工单系统写入工单内容和沟通记录"
    },
    {
      "id": "flow_4",
      "stage": "存储/使用",
      "source_entity_id": "ticket_system",
      "target_entity_id": "user_center",
      "data_item_ids": [
        1
      ],
      "description": "工单系统发起账号信息查询请求"
    },
    {
      "id": "flow_5",
      "stage": "存储/使用",
      "source_entity_id": "user_center",
      "target_entity_id": "cs_workbench",
      "data_item_ids": [
        2,
        5
      ],
      "description": "用户中心向客服工作台返回手机号和历史订单信息供核验"
    },
    {
      "id": "flow_7",
      "stage": "分享/传输",
      "source_entity_id": "cs_workbench",
      "target_entity_id": "weifu_cloud",
      "data_item_ids": [
        1,
        3,
        7
      ],
      "description": "客服工作台向微服Cloud发送账号ID、问题描述和附件元数据"
    },
    {
      "id": "flow_8",
      "stage": "分享/传输",
      "source_entity_id": "weifu_cloud",
      "target_entity_id": "cs_workbench",
      "data_item_ids": [
        8,
        9,
        10
      ],
      "description": "微服Cloud返回机器人答复、工单编号和会话摘要"
    },
    {
      "id": "flow_9",
      "stage": "归档/删除",
      "source_entity_id": "cs_workbench",
      "target_entity_id": "recording_store",
      "data_item_ids": [
        4,
        6,
        9
      ],
      "description": "客服记录、附件和工单编号归档至录音/会话存储系统"
    }
  ],
  "legend": {
    "notes": [
      "所有流向线使用统一颜色表示同一数据处理活动",
      "数据项差异通过流向线上的编号圆点区分"
    ]
  },
  "lifecycle_flags": {
    "has_share_transfer": true,
    "has_archive_delete": true
  },
  "archive_delete": {
    "retention_entities": [
      "recording_store"
    ],
    "delete_entities": [],
    "flows": []
  },
  "generation_constraints": {
    "title_format": "{business_name}——{activity_name}",
    "required_stages": [
      "信息收集",
      "存储/使用",
      "分享/传输",
      "归档/删除"
    ],
    "required_lanes": [
      "数据主体",
      "内部人员",
      "内部系统",
      "第三方"
    ],
    "required_legend_sections": [
      "图形类型说明",
      "数据项编号清单",
      "数据处理活动流向说明"
    ],
    "enforce_unique_data_item_ids": true,
    "enforce_single_entity_instance_preferred": true
  },
  "prompt_hint": "请根据本 JSON 生成公司标准 Data Flow 图，输出为 draw.io 原生 .drawio 文件。必须保留四个一级阶段和四个固定泳道。图右侧必须包含图形图例、数据项编号清单和数据处理活动流向说明。所有主数据流使用统一 activity_color，同一编号的数据项可在多条路径中重复出现，但编号释义必须唯一。"
}
